#!/usr/bin/env ruby

require 'dotenv/load'

$LOAD_PATH.unshift(File.expand_path('../../lib', __FILE__))
require 'research_assistant'
require 'securerandom'

def main
  topic = ARGV[0] || "sky is blue"
  research_id = SecureRandom.uuid
  pp "Research ID: #{research_id}"
  pp "Research Dir: #{ResearchAssistant.config.research_dir}"

  # Initialize components
  json_api_client = ResearchAssistant::OllamaInterface::JsonApiClient.new(model: ResearchAssistant.config.memory_agent_model)
  writer_api_client = ResearchAssistant::OllamaInterface::WriterApiClient.new
  reasoning_api_client = ResearchAssistant::OllamaInterface::ReasoningClient.new

  insights_extractor = ResearchAssistant::CoreEngine::InsightsExtractor.new
  concept_extractor = ResearchAssistant::CoreEngine::ConceptExtractor.new
  gap_detector = ResearchAssistant::CoreEngine::GapDetector.new
  questions_engine = ResearchAssistant::CoreEngine::QuestionEngine.new
  relations_finder = ResearchAssistant::CoreEngine::RelationsFinder.new
  generic_command = ResearchAssistant::CoreEngine::GenericCommand.new
  file_manager = ResearchAssistant::MemoryAgent::FileManager.new(research_id)
  memory_manager = file_manager.memory_manager

  agent_action_executor = ResearchAssistant::MemoryAgent::AgentActionExecutor.new(
    insights_extractor: insights_extractor,
    concept_extractor: concept_extractor,
    gap_detector: gap_detector,
    questions_engine: questions_engine,
    relations_finder: relations_finder,
    generic_command: generic_command,
    memory_manager: memory_manager
  )

  pp "Type of file_manager before AgentManager.new: #{file_manager.class}"
  agent_manager = ResearchAssistant::MemoryAgent::AgentManager.new(
    json_api_client,
    writer_api_client,
    file_manager,
    agent_action_executor
  )

  pp "Run memory agent on topic: #{topic}"

  # For now, we'll start with an empty article.
  # In a real scenario, you might want to generate an initial article first.
  generated_article = ""

  agent_manager.run(topic, generated_article)

  pp "job done"
end

main if __FILE__ == $0
